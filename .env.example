# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is gitignored — never commit credentials.
#
# These are read by runner.py when the "Run plan" button is clicked. The
# values get embedded into the agent's wrapper prompt so it knows what to
# type into the FLEXCUBE login screen.
#
# All names are FLEXCUBE_-prefixed on purpose: Windows always sets a system
# variable called USERNAME (your OS login), and an unprefixed name would
# silently shadow the value you intended to provide here.

# Required ----------------------------------------------------------------
FLEXCUBE_BASE_URL=https://your-flexcube-host.example.com/
FLEXCUBE_USERNAME=your_maker_user
FLEXCUBE_PASSWORD=your_maker_password

# Optional — only needed if you re-run with the maker-checker authorize
# step. v1.1 stops after the maker Save, so these can stay blank for first
# runs.
FLEXCUBE_ACCORDER_AUTH_USERNAME=
FLEXCUBE_ACCORDER_AUTH_PASSWORD=

# Optional — only set this if you registered the Playwright MCP server
# under a non-default name. Default: "playwright" (matches the recommended
# `claude mcp add playwright -- npx -y "@playwright/mcp@latest"` setup).
# PLAYWRIGHT_MCP_NAME=playwright
